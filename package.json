{
  "name": "@kovartravis/neuron",
  "version": "1.1.1",
  "description": "Local-only agent memory store CLI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "neuron": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
